CATTS_API_KEY=
CATTS_API_PORT=59200
CATTS_WORKER_URL=
CATTS_OCR_ENGINE=none
CATTS_TTS_ENGINE=kokoro
# TTS engine: xtts | kokoro | pocket | edge | chatterbox | gptsovits
CATTS_KOKORO_URL=http://127.0.0.1:8880
CATTS_KOKORO_VOICE=af_bella
# Optional: pin your voice id (else first ready voice is used)
CATTS_DEFAULT_VOICE_ID=
# Set to 1 only after accepting Coqui XTTS v2 CPML/commercial terms.
CATTS_ACCEPT_COQUI_CPML=
